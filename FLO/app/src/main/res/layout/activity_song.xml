<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <ImageButton
        android:id="@+id/song_setting_ib"
        android:layout_width="25dp"
        android:layout_height="25dp"
        android:src="@drawable/btn_player_setting"
        android:scaleType="fitXY"
        android:background="@color/white"
        android:layout_marginTop="40dp"
        android:layout_marginStart="20dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <ImageButton
        android:id="@+id/song_eq_ib"
        android:layout_width="25dp"
        android:layout_height="25dp"
        android:src="@drawable/btn_player_eq_off"
        android:scaleType="fitXY"
        android:background="@color/white"
        android:layout_marginStart="10dp"
        app:layout_constraintTop_toTopOf="@id/song_setting_ib"
        app:layout_constraintBottom_toBottomOf="@id/song_setting_ib"
        app:layout_constraintStart_toEndOf="@id/song_setting_ib" />

    <ImageButton
        android:id="@+id/song_down_ib"
        android:layout_width="25dp"
        android:layout_height="25dp"
        android:src="@drawable/nugu_btn_down"
        android:scaleType="fitXY"
        android:background="@color/white"
        android:layout_marginEnd="20dp"
        app:layout_constraintTop_toTopOf="@id/song_eq_ib"
        app:layout_constraintBottom_toBottomOf="@id/song_eq_ib"
        app:layout_constraintEnd_toEndOf="parent" />

    <ImageButton
        android:id="@+id/song_more_ib"
        android:layout_width="25dp"
        android:layout_height="25dp"
        android:src="@drawable/btn_player_more"
        android:scaleType="fitXY"
        android:background="@color/white"
        android:layout_marginTop="15dp"
        app:layout_constraintTop_toBottomOf="@id/song_down_ib"
        app:layout_constraintStart_toStartOf="@id/song_down_ib"
        app:layout_constraintEnd_toEndOf="@id/song_down_ib" />


    <TextView
        android:id="@+id/song_title_tv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="제목"
        android:textSize="18sp"
        android:textColor="@color/black"
        android:textStyle="bold"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toTopOf="@id/song_more_ib"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/song_singer_tv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="가수"
        android:textSize="14sp"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toBottomOf="@id/song_title_tv"
        app:layout_constraintStart_toStartOf="@id/song_title_tv"
        app:layout_constraintEnd_toEndOf="@id/song_title_tv" />

    <ImageButton
        android:id="@+id/song_singer_more"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:src="@drawable/btn_main_arrow_more"
        android:scaleType="fitXY"
        android:background="@color/white"
        app:layout_constraintTop_toTopOf="@id/song_singer_tv"
        app:layout_constraintBottom_toBottomOf="@id/song_singer_tv"
        app:layout_constraintStart_toEndOf="@id/song_singer_tv" />

    <ImageView
        android:id="@+id/song_album_iv"
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:src="@drawable/img_album_exp"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/song_singer_tv"
        app:layout_constraintStart_toStartOf="@id/song_singer_tv"
        app:layout_constraintEnd_toEndOf="@id/song_singer_tv" />

    <TextView
        android:id="@+id/song_lyric1_tv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="lyric line"
        android:textSize="14sp"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/song_album_iv"
        app:layout_constraintStart_toStartOf="@id/song_album_iv"
        app:layout_constraintEnd_toEndOf="@id/song_album_iv" />

    <TextView
        android:id="@+id/song_lyric2_tv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="lyric line"
        android:textSize="14sp"
        android:layout_marginTop="5dp"
        app:layout_constraintTop_toBottomOf="@id/song_lyric1_tv"
        app:layout_constraintStart_toStartOf="@id/song_lyric1_tv"
        app:layout_constraintEnd_toEndOf="@id/song_lyric1_tv" />



    <LinearLayout
        android:id="@+id/song_like_ib_layout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        app:layout_constraintStart_toStartOf="@id/song_album_iv"
        app:layout_constraintEnd_toEndOf="@id/song_album_iv"
        app:layout_constraintTop_toBottomOf="@id/song_lyric2_tv" >

        <ImageButton
            android:id="@+id/song_like_ib"
            android:layout_width="25dp"
            android:layout_height="25dp"
            android:src="@drawable/ic_my_like_off"
            android:scaleType="fitXY"
            android:background="@color/white" />

        <ImageButton
            android:id="@+id/song_unlike_ib"
            android:layout_width="25dp"
            android:layout_height="25dp"
            android:src="@drawable/btn_player_unlike_off"
            android:scaleType="fitXY"
            android:background="@color/white"
            android:layout_marginStart="50dp" />

    </LinearLayout>

    <SeekBar
        android:id="@+id/song_progress_sb"
        android:layout_width="match_parent"
        android:layout_height="10dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="20dp"
        android:background="@android:color/transparent"
        android:paddingStart="0dp"
        android:paddingEnd="0dp"
        android:progress="0"
        android:progressBackgroundTint="@color/song_player_bg"
        android:progressTint="@color/song_player"
        android:thumb="@color/transparent"
        android:max="100000"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/song_like_ib_layout" />

    <TextView
        android:id="@+id/song_start_time_tv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="00:00"
        android:textColor="@color/select_color"
        app:layout_constraintStart_toStartOf="@id/song_progress_sb"
        app:layout_constraintTop_toBottomOf="@id/song_progress_sb" />

    <TextView
        android:id="@+id/song_end_time_tv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="00:00"
        app:layout_constraintEnd_toEndOf="@id/song_progress_sb"
        app:layout_constraintTop_toBottomOf="@id/song_progress_sb" />

    <LinearLayout
        android:id="@+id/song_player_layout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/song_progress_sb"
        app:layout_constraintBottom_toTopOf="@id/song_related_ib" >

        <ImageButton
            android:id="@+id/song_previous_ib"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:src="@drawable/btn_miniplayer_previous"
            android:scaleType="centerInside"
            android:background="@color/white"
            android:layout_marginEnd="10dp" />

        <ImageButton
            android:id="@+id/song_play_ib"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:src="@drawable/btn_player_play"
            android:scaleType="centerInside"
            android:background="@color/white" />

        <ImageButton
            android:id="@+id/song_pause_ib"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:src="@drawable/btn_miniplay_pause"
            android:scaleType="centerInside"
            android:background="@color/white"
            android:visibility="gone" />

        <ImageButton
            android:id="@+id/song_next_ib"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:src="@drawable/btn_miniplayer_next"
            android:scaleType="centerInside"
            android:background="@color/white"
            android:layout_marginStart="10dp" />

    </LinearLayout>

    <ImageButton
        android:id="@+id/song_related_ib"
        android:layout_width="60dp"
        android:layout_height="30dp"
        android:src="@drawable/btn_player_related"
        android:scaleType="centerInside"
        android:background="@color/white"
        android:layout_marginBottom="20dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />



    <ImageButton
        android:id="@+id/song_repeat_ib"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:src="@drawable/nugu_btn_repeat_inactive"
        android:scaleType="centerInside"
        android:background="@color/transparent"
        android:layout_marginEnd="30dp"
        app:layout_constraintTop_toTopOf="@id/song_player_layout"
        app:layout_constraintBottom_toBottomOf="@id/song_player_layout"
        app:layout_constraintEnd_toStartOf="@id/song_player_layout" />

    <ImageButton
        android:id="@+id/song_repeat_act_ib"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:src="@drawable/nugu_btn_repeat_active"
        android:scaleType="centerInside"
        android:background="@color/transparent"
        android:layout_marginEnd="30dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="@id/song_player_layout"
        app:layout_constraintBottom_toBottomOf="@id/song_player_layout"
        app:layout_constraintEnd_toStartOf="@id/song_player_layout" />

    <ImageButton
        android:id="@+id/song_random_ib"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:src="@drawable/nugu_btn_random_inactive"
        android:scaleType="centerInside"
        android:background="@android:color/transparent"
        android:layout_marginStart="30dp"
        app:layout_constraintTop_toTopOf="@id/song_player_layout"
        app:layout_constraintBottom_toBottomOf="@id/song_player_layout"
        app:layout_constraintStart_toEndOf="@id/song_player_layout" />

    <ImageButton
        android:id="@+id/song_random_act_ib"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:src="@drawable/nugu_btn_random_active"
        android:scaleType="centerInside"
        android:background="@android:color/transparent"
        android:layout_marginStart="30dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="@id/song_player_layout"
        app:layout_constraintBottom_toBottomOf="@id/song_player_layout"
        app:layout_constraintStart_toEndOf="@id/song_player_layout" />

    <ImageButton
        android:id="@+id/song_instagram_ib"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:src="@drawable/btn_actionbar_instagram"
        android:scaleType="centerInside"
        android:background="@color/white"
        android:layout_marginStart="20dp"
        android:layout_marginBottom="20dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <ImageButton
        android:id="@+id/song_player_list"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:src="@drawable/btn_player_go_list"
        android:scaleType="centerInside"
        android:background="@color/white"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="20dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />


</androidx.constraintlayout.widget.ConstraintLayout>