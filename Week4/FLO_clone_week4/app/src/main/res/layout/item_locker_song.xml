<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:paddingVertical="15dp"
    android:paddingStart="15dp">

    <androidx.cardview.widget.CardView
        android:id="@+id/item_song_cv"
        android:layout_width="50dp"
        android:layout_height="50dp"
        app:cardCornerRadius="10dp" >

        <ImageView
            android:id="@+id/item_song_cover_iv"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/img_album_exp" />

    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/item_song_title_tv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="제목"
        android:textSize="16sp"
        android:textColor="@color/black"
        android:layout_marginStart="10dp"
        app:layout_constraintStart_toEndOf="@id/item_song_cv"
        app:layout_constraintTop_toTopOf="@id/item_song_cv"
        app:layout_constraintBottom_toTopOf="@id/item_song_singer_tv" />

    <TextView
        android:id="@+id/item_song_singer_tv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="가수"
        android:textSize="14sp"
        android:layout_marginStart="10dp"
        app:layout_constraintStart_toEndOf="@id/item_song_cv"
        app:layout_constraintTop_toBottomOf="@id/item_song_title_tv"
        app:layout_constraintBottom_toBottomOf="@id/item_song_cv" />

    <ImageButton
        android:id="@+id/item_song_more_ib"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:src="@drawable/btn_player_more"
        android:scaleType="centerInside"
        android:background="@color/transparent"
        android:layout_marginEnd="10dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <ImageButton
        android:id="@+id/item_song_play_ib"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:src="@drawable/btn_player_play"
        android:scaleType="centerInside"
        android:background="@color/transparent"
        android:layout_marginEnd="5dp"
        app:layout_constraintTop_toTopOf="@id/item_song_more_ib"
        app:layout_constraintBottom_toBottomOf="@id/item_song_more_ib"
        app:layout_constraintEnd_toStartOf="@id/item_song_more_ib" />



</androidx.constraintlayout.widget.ConstraintLayout>