<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingVertical="10dp"
    android:paddingStart="15dp"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.cardview.widget.CardView
        android:id="@+id/item_locker_album_cv"
        android:layout_width="100dp"
        android:layout_height="100dp"
        app:cardCornerRadius="10dp" >

        <ImageView
            android:id="@+id/item_locker_album_cover_iv"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/img_album_exp" />

    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/item_locker_album_title_tv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="앨범"
        android:textSize="16sp"
        android:textColor="@color/black"
        android:layout_marginTop="10dp"
        android:layout_marginStart="10dp"
        app:layout_constraintStart_toEndOf="@id/item_locker_album_cv"
        app:layout_constraintTop_toTopOf="@id/item_locker_album_cv"
        app:layout_constraintBottom_toTopOf="@id/item_locker_album_singer_tv" />

    <TextView
        android:id="@+id/item_locker_album_singer_tv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="가수"
        android:textSize="14sp"
        android:layout_marginStart="10dp"
        app:layout_constraintStart_toEndOf="@id/item_locker_album_cv"
        app:layout_constraintTop_toBottomOf="@id/item_locker_album_title_tv"
        app:layout_constraintBottom_toTopOf="@id/item_locker_album_info" />

    <TextView
        android:id="@+id/item_locker_album_info"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="발매일 | 앨범 정보"
        android:layout_marginBottom="10dp"
        android:layout_marginStart="10dp"
        app:layout_constraintTop_toBottomOf="@id/item_locker_album_singer_tv"
        app:layout_constraintBottom_toBottomOf="@id/item_locker_album_cv"
        app:layout_constraintStart_toEndOf="@id/item_locker_album_cv" />

    <ImageButton
        android:id="@+id/item_locker_album_more_ib"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:src="@drawable/btn_player_more"
        android:scaleType="centerInside"
        android:background="@color/transparent"
        android:layout_marginEnd="10dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <ImageButton
    android:id="@+id/item_locker_album_play_ib"
    android:layout_width="30dp"
    android:layout_height="30dp"
    android:src="@drawable/btn_player_play"
    android:scaleType="centerInside"
    android:background="@color/transparent"
    android:layout_marginEnd="5dp"
    app:layout_constraintTop_toTopOf="@id/item_locker_album_more_ib"
    app:layout_constraintBottom_toBottomOf="@id/item_locker_album_more_ib"
    app:layout_constraintEnd_toStartOf="@id/item_locker_album_more_ib" />


    <ImageButton
    android:id="@+id/item_locker_album_pause_ib"
    android:layout_width="30dp"
    android:layout_height="30dp"
    android:src="@drawable/btn_miniplay_pause"
    android:scaleType="centerInside"
    android:background="@color/transparent"
    android:layout_marginEnd="5dp"
    android:visibility="gone"
    app:layout_constraintTop_toTopOf="@id/item_locker_album_more_ib"
    app:layout_constraintBottom_toBottomOf="@id/item_locker_album_more_ib"
    app:layout_constraintEnd_toStartOf="@id/item_locker_album_more_ib" />


</androidx.constraintlayout.widget.ConstraintLayout>