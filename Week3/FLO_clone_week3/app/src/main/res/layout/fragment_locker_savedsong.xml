<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <ImageButton
        android:id="@+id/savedsong_select_all_ib"
        android:layout_width="25dp"
        android:layout_height="25dp"
        android:src="@drawable/btn_playlist_select_off"
        android:scaleType="centerInside"
        android:background="@color/transparent"
        android:layout_marginTop="10dp"
        android:layout_marginStart="20dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/savedsong_select_all_tv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="전체 선택"
        android:layout_marginStart="10dp"
        app:layout_constraintTop_toTopOf="@id/savedsong_select_all_ib"
        app:layout_constraintBottom_toBottomOf="@id/savedsong_select_all_ib"
        app:layout_constraintStart_toEndOf="@id/savedsong_select_all_ib" />

    <ImageButton
        android:id="@+id/savedsong_play_all_ib"
        android:layout_width="25dp"
        android:layout_height="25dp"
        android:src="@drawable/icon_browse_arrow_right"
        android:scaleType="centerInside"
        android:background="@color/transparent"
        android:layout_marginStart="20dp"
        app:layout_constraintTop_toTopOf="@id/savedsong_select_all_tv"
        app:layout_constraintBottom_toBottomOf="@id/savedsong_select_all_tv"
        app:layout_constraintStart_toEndOf="@id/savedsong_select_all_tv" />

    <TextView
        android:id="@+id/savedsong_play_all_tv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="전체 듣기"
        android:layout_marginStart="10dp"
        app:layout_constraintTop_toTopOf="@id/savedsong_play_all_ib"
        app:layout_constraintBottom_toBottomOf="@id/savedsong_play_all_ib"
        app:layout_constraintStart_toEndOf="@id/savedsong_play_all_ib" />

    <TextView
        android:id="@+id/savedsong_edit_tv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="편집"
        android:textColor="@color/black"
        android:textStyle="bold"
        android:layout_marginEnd="30dp"
        app:layout_constraintTop_toTopOf="@id/savedsong_play_all_tv"
        app:layout_constraintBottom_toBottomOf="@id/savedsong_play_all_tv"
        app:layout_constraintEnd_toEndOf="parent" />


</androidx.constraintlayout.widget.ConstraintLayout>