<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content" >

        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/home_banner_vp"
            android:layout_width="match_parent"
            android:layout_height="430dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <ImageButton
            android:id="@+id/home_banner_btn_setting_iv"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:src="@drawable/btn_main_setting"
            android:scaleType="centerInside"
            android:background="@android:color/transparent"
            android:layout_marginTop="20dp"
            android:layout_marginEnd="20dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <ImageButton
            android:id="@+id/home_banner_btn_ticket_iv"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:src="@drawable/btn_main_ticket"
            android:scaleType="centerInside"
            android:background="@android:color/transparent"
            android:layout_marginEnd="15dp"
            app:layout_constraintTop_toTopOf="@id/home_banner_btn_setting_iv"
            app:layout_constraintBottom_toBottomOf="@id/home_banner_btn_setting_iv"
            app:layout_constraintEnd_toStartOf="@id/home_banner_btn_setting_iv" />

        <ImageButton
            android:id="@+id/home_banner_btn_nugu_iv"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:src="@drawable/btn_main_mike"
            android:scaleType="centerInside"
            android:background="@android:color/transparent"
            android:layout_marginEnd="15dp"
            app:layout_constraintTop_toTopOf="@id/home_banner_btn_ticket_iv"
            app:layout_constraintBottom_toBottomOf="@id/home_banner_btn_ticket_iv"
            app:layout_constraintEnd_toStartOf="@id/home_banner_btn_ticket_iv" />

        <TextView
            android:id="@+id/home_banner_title_tv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="포근하게 덮어주는 꿈의\n목소리"
            android:textSize="28sp"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:layout_marginStart="20dp"
            android:layout_marginTop="15dp"
            app:layout_constraintTop_toBottomOf="@id/home_banner_btn_nugu_iv"
            app:layout_constraintStart_toStartOf="parent" />

        <ImageButton
            android:id="@+id/home_banner_btn_play_iv"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:src="@drawable/btn_panel_play_large"
            android:scaleType="centerInside"
            android:background="@android:color/transparent"
            android:layout_marginTop="15dp"
            android:layout_marginEnd="20dp"
            app:layout_constraintTop_toBottomOf="@id/home_banner_title_tv"
            app:layout_constraintEnd_toEndOf="parent" />



        <TextView
            android:id="@+id/home_banner_album_info_tv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="총 _곡 yyyy.mm.dd"
            android:textSize="12sp"
            android:textColor="@color/white"
            android:layout_marginStart="20dp"
            android:layout_marginBottom="15dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintBottom_toTopOf="@id/home_banner_album_img1_iv" />

        <ImageView
            android:id="@+id/home_banner_album_img1_iv"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/img_album_exp"
            android:layout_marginStart="20dp"
            android:layout_marginBottom="30dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintBottom_toTopOf="@id/home_banner_album_img2_iv" />

        <TextView
            android:id="@+id/home_banner_album_title1_tv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="제목"
            android:textSize="15dp"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:layout_marginStart="15dp"
            app:layout_constraintTop_toTopOf="@id/home_banner_album_img1_iv"
            app:layout_constraintStart_toEndOf="@id/home_banner_album_img1_iv"
            app:layout_constraintBottom_toTopOf="@id/home_banner_album_singer1_tv" />

        <TextView
            android:id="@+id/home_banner_album_singer1_tv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="가수"
            android:textSize="15dp"
            android:textColor="@color/white"
            android:layout_marginStart="15dp"
            app:layout_constraintStart_toEndOf="@id/home_banner_album_img1_iv"
            app:layout_constraintBottom_toBottomOf="@id/home_banner_album_img1_iv"
            app:layout_constraintTop_toBottomOf="@id/home_banner_album_title1_tv" />

        <ImageView
            android:id="@+id/home_banner_album_img2_iv"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/img_album_exp"
            android:layout_marginStart="20dp"
            android:layout_marginBottom="30dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintBottom_toBottomOf="@id/home_banner_vp" />

        <TextView
            android:id="@+id/home_banner_album_title2_tv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="제목"
            android:textSize="15dp"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:layout_marginStart="15dp"
            app:layout_constraintTop_toTopOf="@id/home_banner_album_img2_iv"
            app:layout_constraintStart_toEndOf="@id/home_banner_album_img2_iv"
            app:layout_constraintBottom_toTopOf="@id/home_banner_album_singer2_tv" />

        <TextView
            android:id="@+id/home_banner_album_singer2_tv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="가수"
            android:textSize="15dp"
            android:textColor="@color/white"
            android:layout_marginStart="15dp"
            app:layout_constraintStart_toEndOf="@id/home_banner_album_img2_iv"
            app:layout_constraintBottom_toBottomOf="@id/home_banner_album_img2_iv"
            app:layout_constraintTop_toBottomOf="@id/home_banner_album_title2_tv" />



        <TextView
            android:id="@+id/home_today_music_title_tv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="오늘 발매 음악"
            android:textSize="20sp"
            android:textColor="@color/black"
            android:textStyle="bold"
            android:layout_marginTop="20dp"
            android:layout_marginStart="20dp"
            app:layout_constraintTop_toBottomOf="@id/home_banner_vp"
            app:layout_constraintStart_toStartOf="parent" />

        <ImageButton
            android:id="@+id/home_today_music_title_btn_iv"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/btn_main_arrow_more"
            android:scaleType="centerInside"
            android:background="@android:color/transparent"
            app:layout_constraintStart_toEndOf="@id/home_today_music_title_tv"
            app:layout_constraintTop_toTopOf="@id/home_today_music_title_tv"
            app:layout_constraintBottom_toBottomOf="@id/home_today_music_title_tv" />

        <TextView
            android:id="@+id/home_today_music_international_tv"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:text="해외"
            android:textSize="18sp"
            android:layout_marginTop="20dp"
            android:layout_marginEnd="20dp"
            app:layout_constraintTop_toBottomOf="@id/home_banner_vp"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/home_today_music_domestic_tv"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:text="국내"
            android:textSize="18sp"
            android:layout_marginEnd="20dp"
            app:layout_constraintTop_toTopOf="@id/home_today_music_international_tv"
            app:layout_constraintBottom_toBottomOf="@id/home_today_music_international_tv"
            app:layout_constraintEnd_toStartOf="@id/home_today_music_international_tv" />

        <TextView
            android:id="@+id/home_today_music_global_tv"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:text="종합"
            android:textSize="18sp"
            android:textColor="@color/select_color"
            android:layout_marginEnd="20dp"
            app:layout_constraintTop_toTopOf="@id/home_today_music_domestic_tv"
            app:layout_constraintBottom_toBottomOf="@id/home_today_music_domestic_tv"
            app:layout_constraintEnd_toStartOf="@id/home_today_music_domestic_tv" />



        <LinearLayout
            android:id="@+id/home_today_music_layout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/home_today_music_title_tv"
            app:layout_constraintStart_toStartOf="parent" >

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/home_today_music_album1_layout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="20dp" >

                <ImageView
                    android:id="@+id/home_today_music_album1_iv"
                    android:layout_width="150dp"
                    android:layout_height="150dp"
                    android:src="@drawable/img_album_exp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent" />

                <ImageButton
                    android:id="@+id/home_today_music_album1_btn_play"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/widget_black_play"
                    android:scaleType="centerInside"
                    android:background="@android:color/transparent"
                    android:layout_marginEnd="10dp"
                    android:layout_marginBottom="7dp"
                    app:layout_constraintEnd_toEndOf="@id/home_today_music_album1_iv"
                    app:layout_constraintBottom_toBottomOf="@id/home_today_music_album1_iv" />

                <TextView
                    android:id="@+id/home_today_music_title1_tv"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="제목"
                    android:textSize="15sp"
                    android:textColor="@color/black"
                    android:layout_marginTop="10dp"
                    app:layout_constraintTop_toBottomOf="@id/home_today_music_album1_iv"
                    app:layout_constraintStart_toStartOf="parent" />

                <TextView
                    android:id="@+id/home_today_music_singer1_tv"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="가수"
                    android:textSize="12sp"
                    app:layout_constraintTop_toBottomOf="@id/home_today_music_title1_tv"
                    app:layout_constraintStart_toStartOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/home_today_music_album2_layout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="20dp" >

                <ImageView
                    android:id="@+id/home_today_music_album2_iv"
                    android:layout_width="150dp"
                    android:layout_height="150dp"
                    android:src="@drawable/img_album_exp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent" />

                <ImageButton
                    android:id="@+id/home_today_music_album2_btn_play"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/widget_black_play"
                    android:scaleType="centerInside"
                    android:background="@android:color/transparent"
                    android:layout_marginEnd="10dp"
                    android:layout_marginBottom="7dp"
                    app:layout_constraintBottom_toBottomOf="@id/home_today_music_album2_iv"
                    app:layout_constraintEnd_toEndOf="@id/home_today_music_album2_iv" />

                <TextView
                    android:id="@+id/home_today_music_title2_tv"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="제목"
                    android:textSize="15sp"
                    android:textColor="@color/black"
                    android:layout_marginTop="10dp"
                    app:layout_constraintTop_toBottomOf="@id/home_today_music_album2_iv"
                    app:layout_constraintStart_toStartOf="parent" />

                <TextView
                    android:id="@+id/home_today_music_singer2_tv"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="가수"
                    android:textSize="12sp"
                    app:layout_constraintTop_toBottomOf="@id/home_today_music_title2_tv"
                    app:layout_constraintStart_toStartOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/home_today_music_album3_layout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="20dp" >

                <ImageView
                    android:id="@+id/home_today_music_album3_iv"
                    android:layout_width="150dp"
                    android:layout_height="150dp"
                    android:src="@drawable/img_album_exp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent" />

                <ImageButton
                    android:id="@+id/home_today_music_album3_btn_play"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/widget_black_play"
                    android:scaleType="centerInside"
                    android:background="@android:color/transparent"
                    android:layout_marginEnd="10dp"
                    android:layout_marginBottom="7dp"
                    app:layout_constraintEnd_toEndOf="@id/home_today_music_album3_iv"
                    app:layout_constraintBottom_toBottomOf="@id/home_today_music_album3_iv" />

                <TextView
                    android:id="@+id/home_today_music_title3_tv"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="제목"
                    android:textSize="15sp"
                    android:textColor="@color/black"
                    android:layout_marginTop="10dp"
                    app:layout_constraintTop_toBottomOf="@id/home_today_music_album3_iv"
                    app:layout_constraintStart_toStartOf="parent" />

                <TextView
                    android:id="@+id/home_today_music_singer3_tv"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="가수"
                    android:textSize="12sp"
                    app:layout_constraintTop_toBottomOf="@id/home_today_music_title3_tv"
                    app:layout_constraintStart_toStartOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>