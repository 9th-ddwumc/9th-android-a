<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.example.androidA.HomeFragment"
        android:label="홈"
        tools:layout="@layout/fragment_home" >
        <action
            android:id="@+id/action_homeFragment_to_albumFragment"
            app:destination="@id/albumFragment" />
    </fragment>

    <fragment
        android:id="@+id/lookFragment"
        android:name="com.example.androidA.LookFragment"
        android:label="둘러보기"
        tools:layout="@layout/fragment_look" />

    <fragment
        android:id="@+id/searchFragment"
        android:name="com.example.androidA.SearchFragment"
        android:label="검색"
        tools:layout="@layout/fragment_search" />

    <fragment
        android:id="@+id/lockerFragment"
        android:name="com.example.androidA.LockerFragment"
        android:label="보관함"
        tools:layout="@layout/fragment_locker" />

    <fragment
        android:id="@+id/albumFragment"
        android:name="com.example.androidA.AlbumFragment"
        tools:layout="@layout/fragment_album" >
        <action
            android:id="@+id/action_albumFragment_to_homeFragment"
            app:destination="@id/homeFragment" />
    </fragment>

</navigation>